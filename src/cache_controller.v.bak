`timescale 1ns/1ps

module cache_controller (
    input wire clock,
    input wire rst_n,

    // Interfa?a cu CPU
    input wire [20:0] caddress,
    input wire [31:0] cdin,
    input wire rden,
    input wire wren,
    output wire hit,
    output reg [31:0] cdout,

    // Interfa?a cu Memoria Principal?
    input wire [255:0] mdin,
    output reg [255:0] mdout,
    output reg [17:0] maddress,
    output reg mrden,
    output reg mwren
);

    // Parametri State Machine
    localparam STATE_IDLE       = 3'd0,
               STATE_READ_HIT   = 3'd1,
               STATE_READ_MISS  = 3'd2,
               STATE_WRITE_HIT  = 3'd3,
               STATE_WRITE_MISS = 3'd4,
               STATE_REPLACE    = 3'd5,
               STATE_FETCH      = 3'd6,
               STATE_FILL       = 3'd7;

    reg [2:0] current_state, next_state;

    // Registre interne pentru cereri re?inute
    reg [20:0] req_addr;
    reg        req_read;
    reg        req_write;
    reg [31:0] req_wdata;

    wire [20:0] active_addr = (current_state == STATE_IDLE) ? caddress : req_addr;
    wire [9:0]  active_tag  = active_addr[20:11];
    wire [7:0]  active_idx  = active_addr[10:3];
    wire [2:0]  active_off  = active_addr[2:0];

    // Array-uri pentru cele 4 c?i (256 seturi)
    reg valid_0 [0:255]; reg valid_1 [0:255]; reg valid_2 [0:255]; reg valid_3 [0:255];
    reg dirty_0 [0:255]; reg dirty_1 [0:255]; reg dirty_2 [0:255]; reg dirty_3 [0:255];
    reg [9:0] tag_0 [0:255]; reg [9:0] tag_1 [0:255]; reg [9:0] tag_2 [0:255]; reg [9:0] tag_3 [0:255];
    reg [255:0] mem_0 [0:255]; reg [255:0] mem_1 [0:255]; reg [255:0] mem_2 [0:255]; reg [255:0] mem_3 [0:255];
    
    // Contoare LRU pe 2 bi?i (0=MRU, 3=LRU)
    reg [1:0] lru_0 [0:255]; reg [1:0] lru_1 [0:255]; reg [1:0] lru_2 [0:255]; reg [1:0] lru_3 [0:255];

    // Logica de Hit (Comparare tag-uri simultan)
    wire hit_0 = valid_0[active_idx] && (tag_0[active_idx] == active_tag);
    wire hit_1 = valid_1[active_idx] && (tag_1[active_idx] == active_tag);
    wire hit_2 = valid_2[active_idx] && (tag_2[active_idx] == active_tag);
    wire hit_3 = valid_3[active_idx] && (tag_3[active_idx] == active_tag);

    wire lookup_hit = hit_0 | hit_1 | hit_2 | hit_3;
    assign hit = lookup_hit;

    wire [1:0] hit_way = hit_0 ? 2'd0 :
                         hit_1 ? 2'd1 :
                         hit_2 ? 2'd2 : 2'd3;

    wire [255:0] hit_block = hit_0 ? mem_0[active_idx] :
                             hit_1 ? mem_1[active_idx] :
                             hit_2 ? mem_2[active_idx] : mem_3[active_idx];

    wire [31:0] read_data;
    assign read_data = hit_block[(active_off * 32) +: 32]; // Extragerea cuvântului pe baza offsetului

    // Logica de Victim Selection (Alegerea c?ii de înlocuit folosind LRU)
    wire inv_0 = ~valid_0[active_idx];
    wire inv_1 = ~valid_1[active_idx];
    wire inv_2 = ~valid_2[active_idx];
    wire inv_3 = ~valid_3[active_idx];

    wire [1:0] v_lru_0 = lru_0[active_idx];
    wire [1:0] v_lru_1 = lru_1[active_idx];
    wire [1:0] v_lru_2 = lru_2[active_idx];
    wire [1:0] v_lru_3 = lru_3[active_idx];

    // Prefer? blocurile invalide; dac? toate sunt valide, ia blocul cu LRU == 3
    wire [1:0] victim_way = inv_0 ? 2'd0 :
                            inv_1 ? 2'd1 :
                            inv_2 ? 2'd2 :
                            inv_3 ? 2'd3 :
                            (v_lru_0 == 2'd3) ? 2'd0 :
                            (v_lru_1 == 2'd3) ? 2'd1 :
                            (v_lru_2 == 2'd3) ? 2'd2 : 2'd3;

    wire victim_dirty = (victim_way == 2'd0) ? dirty_0[active_idx] :
                        (victim_way == 2'd1) ? dirty_1[active_idx] :
                        (victim_way == 2'd2) ? dirty_2[active_idx] : dirty_3[active_idx];

    wire [9:0] victim_tag = (victim_way == 2'd0) ? tag_0[active_idx] :
                            (victim_way == 2'd1) ? tag_1[active_idx] :
                            (victim_way == 2'd2) ? tag_2[active_idx] : tag_3[active_idx];

    wire [255:0] victim_block = (victim_way == 2'd0) ? mem_0[active_idx] :
                                (victim_way == 2'd1) ? mem_1[active_idx] :
                                (victim_way == 2'd2) ? mem_2[active_idx] : mem_3[active_idx];

    // State Machine Combinatorial
    always @(*) begin
        next_state = current_state;
        cdout    = 32'd0;
        mdout    = 256'd0;
        maddress = 18'd0;
        mrden    = 1'b0;
        mwren    = 1'b0;
        hit      = 1'b0;

        case (current_state)
            STATE_IDLE: begin
                if (rden && lookup_hit) begin
                    hit = 1'b1;
                    next_state = STATE_READ_HIT;
                end else if (rden) begin
                    next_state = STATE_READ_MISS;
                end else if (wren && lookup_hit) begin
                    hit = 1'b1;
                    next_state = STATE_WRITE_HIT;
                end else if (wren) begin
                    next_state = STATE_WRITE_MISS;
                end
            end
            STATE_READ_HIT: begin
                cdout = read_data;
                next_state = STATE_IDLE;
            end
            STATE_READ_MISS, STATE_WRITE_MISS: begin
                if (victim_dirty) // Dac? blocul ce va fi suprascris a fost modificat, Write-Back
                    next_state = STATE_REPLACE;
                else
                    next_state = STATE_FETCH;
            end
            STATE_REPLACE: begin // Write-Back c?tre memorie
                mwren = 1'b1;
                maddress = {victim_tag, active_idx}; 
                mdout = victim_block;
                next_state = STATE_FETCH;
            end
            STATE_FETCH: begin // Aduce blocul din memorie
                mrden = 1'b1;
                maddress = {active_tag, active_idx};
                next_state = STATE_FILL;
            end
            STATE_FILL: begin
                if (req_read)
                    next_state = STATE_READ_HIT;
                else if (req_write)
                    next_state = STATE_WRITE_HIT;
                else
                    next_state = STATE_IDLE;
            end
            STATE_WRITE_HIT: begin
                next_state = STATE_IDLE;
            end
        endcase
    end

    // Logica pentru update-ul LRU-ului
    wire [1:0] target_way = (current_state == STATE_FILL) ? victim_way : hit_way;
    wire do_lru_update = (current_state == STATE_IDLE && (rden || wren) && lookup_hit) || (current_state == STATE_FILL);
    wire [1:0] target_old_lru = (target_way == 2'd0) ? v_lru_0 :
                                (target_way == 2'd1) ? v_lru_1 :
                                (target_way == 2'd2) ? v_lru_2 : v_lru_3;

    integer i;
    
    // State Machine Secven?ial
    always @(posedge clock or negedge rst_n) begin
        if (!rst_n) begin
            current_state <= STATE_IDLE;
            req_read      <= 1'b0;
            req_write     <= 1'b0;
            req_addr      <= 21'd0;
            req_wdata     <= 32'd0;

            for (i = 0; i < 256; i = i + 1) begin
                valid_0[i] <= 1'b0; valid_1[i] <= 1'b0; valid_2[i] <= 1'b0; valid_3[i] <= 1'b0;
                dirty_0[i] <= 1'b0; dirty_1[i] <= 1'b0; dirty_2[i] <= 1'b0; dirty_3[i] <= 1'b0;
                lru_0[i] <= 2'd0;   lru_1[i] <= 2'd1;   lru_2[i] <= 2'd2;   lru_3[i] <= 2'd3;
            end
        end else begin
            current_state <= next_state;

            // Latch request data
            if (current_state == STATE_IDLE && (rden || wren)) begin
                req_addr  <= caddress;
                req_read  <= rden;
                req_write <= wren;
                req_wdata <= cdin;
            end

            // FILL: Scriem din Memorie în Cache
            if (current_state == STATE_FILL) begin
                case (victim_way)
                    2'd0: begin mem_0[active_idx] <= mdin; tag_0[active_idx] <= active_tag; valid_0[active_idx] <= 1'b1; dirty_0[active_idx] <= 1'b0; end
                    2'd1: begin mem_1[active_idx] <= mdin; tag_1[active_idx] <= active_tag; valid_1[active_idx] <= 1'b1; dirty_1[active_idx] <= 1'b0; end
                    2'd2: begin mem_2[active_idx] <= mdin; tag_2[active_idx] <= active_tag; valid_2[active_idx] <= 1'b1; dirty_2[active_idx] <= 1'b0; end
                    2'd3: begin mem_3[active_idx] <= mdin; tag_3[active_idx] <= active_tag; valid_3[active_idx] <= 1'b1; dirty_3[active_idx] <= 1'b0; end
                endcase
            end

            // WRITE HIT: Suprascriem cuvântul în bloc (Write-allocate se asigur? c? ajungem aici pe Miss)
            if (current_state == STATE_WRITE_HIT) begin
                case (hit_way)
                    2'd0: begin mem_0[active_idx][(active_off * 32) +: 32] <= req_wdata; dirty_0[active_idx] <= 1'b1; end
                    2'd1: begin mem_1[active_idx][(active_off * 32) +: 32] <= req_wdata; dirty_1[active_idx] <= 1'b1; end
                    2'd2: begin mem_2[active_idx][(active_off * 32) +: 32] <= req_wdata; dirty_2[active_idx] <= 1'b1; end
                    2'd3: begin mem_3[active_idx][(active_off * 32) +: 32] <= req_wdata; dirty_3[active_idx] <= 1'b1; end
                endcase
            end

            // LRU Update: Increment?m toate modurile mai mici decât vechea valoare ?i reset?m modul selectat pe 0 (MRU)
            if (do_lru_update) begin
                if (lru_0[active_idx] < target_old_lru) lru_0[active_idx] <= lru_0[active_idx] + 1;
                if (lru_1[active_idx] < target_old_lru) lru_1[active_idx] <= lru_1[active_idx] + 1;
                if (lru_2[active_idx] < target_old_lru) lru_2[active_idx] <= lru_2[active_idx] + 1;
                if (lru_3[active_idx] < target_old_lru) lru_3[active_idx] <= lru_3[active_idx] + 1;

                case (target_way)
                    2'd0: lru_0[active_idx] <= 2'd0;
                    2'd1: lru_1[active_idx] <= 2'd0;
                    2'd2: lru_2[active_idx] <= 2'd0;
                    2'd3: lru_3[active_idx] <= 2'd0;
                endcase
            end
        end
    end

endmodule
